# ============================================================
# Cloudflare Email Worker 环境变量示例
# 复制为 .env 文件（仅本地开发用）
# 生产环境用: npx wrangler secret put <密钥名>
# ============================================================

# 飞书群机器人 Webhook URL（必填，至少一个）
# 在飞书群设置 → 群机器人 → 添加机器人 → Webhook → 复制地址
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/你的机器人的hook_id

# 可选：额外的飞书 Webhook（比如转发到多个群）
FEISHU_WEBHOOK_URL_2=
FEISHU_WEBHOOK_URL_3=

# 可选：自定义邮件处理
ALLOWED_SENDERS=friend@example.com,colleague@example.com
BLOCKED_SENDERS=spam@example.com
FORWARD_TO_FEISHU=true
LOG_LEVEL=info
FEISHU_MSG_TITLE=📬 新邮件通知
